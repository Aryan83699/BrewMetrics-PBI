table _Measures
	lineageTag: 130bd8ab-a8d4-44ad-afef-47622b9a8889

	measure 'Total Sales' = SUM(Transactions[Sales])
		formatString: \$#,0.0;(\$#,0.0);\$#,0.0
		lineageTag: bdea6b58-988e-4fd6-8f5b-b812bc07660c

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'CM Sales' = ```
			VAR selected_month= SELECTEDVALUE('Date Table'[Month])
			          RETURN 
			          TOTALMTD(CALCULATE([Total Sales],'Date Table'[Month]=selected_month),'Date Table'[Date])
			```
		lineageTag: a1f3c649-5bc0-4768-9845-fbcff41e4a76

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'PM Sales' = CALCULATE([CM Sales], DATEADD('Date Table'[Date],-1,MONTH))
		lineageTag: b815858b-17e7-4619-886d-e3712b63acae

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'MoM Growth & Diff Sales' = ```
			
			
			    VAR month_diff= [CM Sales]-[PM Sales]
			    VAR mom = month_diff/ [PM Sales]
			    VAR _sign= IF(month_diff>0 ,"+","")
			    VAR _sign_trend=IF(month_diff>0,"∆","∇")
			
			    RETURN _sign_trend & " " & _sign & FORMAT(mom,"#0.0%" & " | " & _sign & FORMAT(month_diff/1000,"0.0K")) & " " & "vs LM"
			```
		lineageTag: e7b6919f-04c8-4e97-b830-f10a5f72b0a9

	measure 'Total Orders' = DISTINCTCOUNT(Transactions[transaction_id])
		lineageTag: f2578754-7bde-4d8b-8e84-1ac337a69142

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'CM Orders' = ```
			VAR selected_month= SELECTEDVALUE('Date Table'[Month])
			          RETURN 
			          TOTALMTD(CALCULATE([Total Orders],'Date Table'[Month]=selected_month),'Date Table'[Date])
			```
		formatString: 0
		lineageTag: 99b5bb6f-37a4-4762-81fe-6d2589798c9d

	measure 'PM Orders' = CALCULATE([CM Orders], DATEADD('Date Table'[Date],-1,MONTH))
		formatString: 0
		lineageTag: 97362d0d-1c38-4efb-8319-8dd8749b74c1

	measure 'MoM Growth & Diff Orders' = ```
			
			
			    VAR month_diff= [CM Orders]-[PM Orders]
			    VAR mom = month_diff/ [PM Orders]
