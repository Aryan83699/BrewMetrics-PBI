			```
		lineageTag: 9a59a349-5e87-44c5-b517-047089d049bc

	measure 'Total Quantity Sold' = SUM(Transactions[transaction_qty])
		formatString: 0
		lineageTag: 2c4369ad-1c10-4f55-aa14-48a6da5021e6

